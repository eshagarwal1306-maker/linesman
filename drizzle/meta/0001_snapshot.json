      "checkConstraints": {
        "txline_credentials_duration_weeks_check": {
          "name": "txline_credentials_duration_weeks_check",
          "value": "(\"txline_credentials\".\"setup_state\" = 'guest_created' AND \"txline_credentials\".\"duration_weeks\" IS NULL)\n        OR (\"txline_credentials\".\"setup_state\" IN ('subscribed', 'activated')\n          AND \"txline_credentials\".\"duration_weeks\" IS NOT NULL\n          AND \"txline_credentials\".\"duration_weeks\" = 4)"
        },
        "txline_credentials_service_level_check": {
          "name": "txline_credentials_service_level_check",
          "value": "(\"txline_credentials\".\"setup_state\" = 'guest_created' AND \"txline_credentials\".\"service_level_id\" IS NULL)\n        OR (\"txline_credentials\".\"setup_state\" IN ('subscribed', 'activated')\n          AND \"txline_credentials\".\"network\" = 'devnet'\n          AND \"txline_credentials\".\"service_level_id\" IS NOT NULL\n          AND \"txline_credentials\".\"service_level_id\" = 1)\n        OR (\"txline_credentials\".\"setup_state\" IN ('subscribed', 'activated')\n          AND \"txline_credentials\".\"network\" = 'mainnet'\n          AND \"txline_credentials\".\"service_level_id\" IS NOT NULL\n          AND \"txline_credentials\".\"service_level_id\" IN (1, 12))"
        }
      },
