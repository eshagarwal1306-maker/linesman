# --- Required for the app to boot -----------------------------------------

# Neon Postgres connection string. Used for sessions, TxLINE credentials,
# and (once `pnpm record` has run) recorded replay packets.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# 32-byte key, base64-encoded, used to encrypt TxLINE JWTs/API tokens at
# rest. Generate one with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY_BASE64=

# --- Optional — sensible defaults exist for all of these -------------------

# Session cookie name.
SESSION_COOKIE_NAME=txline_session

# Public origin of this deployment (used to build absolute callback URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solana RPC endpoints. Public defaults work but are rate-limited — swap in
# a dedicated RPC provider (Helius, Triton, QuickNode…) for production.
NEXT_PUBLIC_DEVNET_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# --- Showcase mode (Replay tab / cold-start demo) ---------------------------

# Which recording the app auto-plays when no live TxLINE session is active.
# Falls back to the seeded mock story if this recording has no packets yet.
SHOWCASE_RECORDING_ID=wc26-final

# Playback speed multiplier for the auto-started showcase loop.
SHOWCASE_SPEED=30

# --- `pnpm record` (headless recorder — see docs/ONCHAIN.md / FRICTION.md) --
# Not read by the Next.js app itself; only by scripts/record.ts.

# Shared secret the recorder script presents to POST /api/internal/record.
RECORDER_SECRET=

# uuid of the (your own) user row whose activated TxLINE credential to tap.
RECORDER_USER_ID=

RECORDER_NETWORK=devnet

# Base URL of the running app the recorder script should hit.
BASE_URL=http://localhost:3000

# --- `pnpm verify` (headless on-chain proof CLI — see docs/ONCHAIN.md) ------
# Not read by the Next.js app itself; only by scripts/verify-cli.ts.

TXLINE_JWT=
TXLINE_API_TOKEN=
NETWORK=devnet
